# Server port
PORT=3001

# Storage provider: "memory" or "azure"
STORAGE_PROVIDER=memory

# Azure Storage (only needed if STORAGE_PROVIDER=azure)
AZURE_STORAGE_CONNECTION_STRING=

# API authentication token — protects all API routes
# Generate a secure random token, e.g.: openssl rand -hex 32
API_AUTH_TOKEN=

# LLM provider API keys
LLM_API_KEY_ANTHROPIC=
LLM_API_KEY_OPENAI=

# Default LLM provider: "anthropic" or "openai" (auto-detected from keys if omitted)
LLM_DEFAULT_PROVIDER=

# Default model (e.g. claude-sonnet-4-20250514, gpt-4o)
LLM_DEFAULT_MODEL=

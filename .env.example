# Server port (default: 5999)
PORT=5999

# Storage provider: "memory" (default) or "azure"
# Memory storage loses all data on restart.
# Azure support is not yet implemented — contributions welcome.
STORAGE_PROVIDER=memory

# Azure Storage (required if STORAGE_PROVIDER=azure)
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...

# API authentication token (optional, not yet enforced)
# API_AUTH_TOKEN=your-secret-token
